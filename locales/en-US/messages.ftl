# DB
db-init-success = awq database ready to use
not-awq-db-found = awq database not founded

# KEYS
keys-generated = awq signing keys has been generated successfully

# Health
hook-success = hook return a success exit code
hook-failure = hook return a failure exit code
warning-pre-commit-hooks-empty = pre-commit hooks is empty
warning-post-commit-hooks-empty = post-commit hooks is empty  
warning-pre-push-hooks-empty = pre-push hooks is empty
warning-post-push-hooks-empty = post-push hooks is empty
pre-commit-hooks-not-empty = hooks founded for pre-commit
post-commit-hooks-not-empty = hooks founded for post-commit
pre-push-hooks-not-empty = hooks founded for pre-push
post-push-hooks-not-empty = hooks founded for post-push

# Commit
commit-created = Commit successfully created
commit-sent = Commit successfully pushed
commit-no-sent = Failed to push commit
ticket-closed-successfully = Ticket marked as DONE
failed-to-close-ticket = Could not close the associated ticket
signature-is-valid = Commit signature verified


# Init

cant-init-the-home = It's no possible to init the home directory
use-memory = Not database has been founded use memory run `awq init` first 
